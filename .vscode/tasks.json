{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure Debug",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\cmake.exe",
      "args": [
        "--preset",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Debug",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\cmake.exe",
      "args": [
        "--build",
        "--preset",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: Configure Debug",
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "CMake: Run Debug",
      "type": "process",
      "command": "${workspaceFolder}\\build\\debug\\Visualize3D.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: Build Debug",
      "problemMatcher": []
    }
  ]
}
